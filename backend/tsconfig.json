{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@tc/shared": ["../shared/src/index.ts"],
      "@tc/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
